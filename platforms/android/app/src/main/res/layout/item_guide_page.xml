<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:id="@+id/img_guide_main"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_marginBottom="32dp"
        android:contentDescription="Travel Guide Illustration"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/txt_guide_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Step Title"
        android:textAlignment="center"
        android:textColor="@color/purple_metro"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txt_guide_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Step description goes here with details for the user."
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="18sp" />

</LinearLayout>
