<?xml version='1.0' encoding='utf-8'?>
<widget id="com.girish.nammametrosahaya" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>NammaMetro</name>
    <description>
        App to calculate fare, distance etc while travelling in Bangalore metro. Has a map of metro and can recharge your metro cards also.
    </description>
    <author email="girishgoudakodibasanagoudra@gmail.com">
        Designed by Girishgouda
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <allow-intent href="market:*" />
    <preference name="loglevel" value="DEBUG" />
</widget>
